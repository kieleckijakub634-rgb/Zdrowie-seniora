{
  "appId": "com.zdrowieseniora.app",
  "appName": "Zdrowie Seniora",
  "webDir": "www",
  "ios": {
    "allowsInlineMediaPlayback": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 3000,
      "launchAutoHide": true,
      "backgroundColor": "#1A2535",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0B3934"
    }
  }
}
